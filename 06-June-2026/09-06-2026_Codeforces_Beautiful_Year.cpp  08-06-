#include <iostream>
#include <string>
#include <set>

using namespace std;

/**
 * Checks if all digits in a year are distinct.
 * @param year The year to check.
 * @return True if distinct, false otherwise.
 */
bool hasDistinctDigits(int year) {
    string s = to_string(year);
    set<char> digits;
    for (char c : s) {
        if (digits.count(c)) {
            return false;
        }
        digits.insert(c);
    }
    return true;
}

int main() {
    // Optimization for faster I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int y;
    if (!(cin >> y)) return 0;

    // Search for the next year with distinct digits
    int nextYear = y + 1;
    while (!hasDistinctDigits(nextYear)) {
        nextYear++;
    }

    cout << nextYear << endl;

    return 0;
}
